// Signal_api clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace signal_api {

    entity Channel {
        id: string @unique
        name: string
        type: string
        topic: string
        memberCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Message {
        id: string @unique
        channelId: string
        authorId: string
        body: string
        sentAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity User {
        id: string @unique
        handle: string
        displayName: string
        verified: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Room {
        id: string @unique
        name: string
        maxParticipants: integer
        recording: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Stream {
        id: string @unique
        roomId: string
        status: string
        bitrate: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Webhook {
        id: string @unique
        event: string
        url: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
